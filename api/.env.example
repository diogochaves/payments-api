# Payments API — Local Development Configuration
# Copy this file to .env and fill in your values.
# .env is ignored by git — never commit secrets.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PORT=3011
NODE_ENV=development
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Asaas provider
# ---------------------------------------------------------------------------
ASAAS_MOCK=true
ASAAS_TOKEN=your_asaas_sandbox_token_here
ASAAS_URL=https://api-sandbox.asaas.com
ASAAS_WEBHOOK_TOKEN=
# Local NestJS default is sync. SAM/LocalStack deploy overrides this to async.
WEBHOOK_PROCESSING_MODE=sync
WEBHOOK_QUEUE_URL=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
INVOICE_REPOSITORY=dynamo
DYNAMO_MOCK=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DYNAMODB_ENDPOINT=http://localhost.localstack.cloud:4566
AWS_SQS_ENDPOINT=http://localhost.localstack.cloud:4566

# ---------------------------------------------------------------------------
# Datadog
#
# PRÉ-REQUISITO LOCAL: um DD Agent deve estar rodando para que traces e métricas
# cheguem ao Datadog. Suba o agente com Docker antes de ligar o tracing:
#
#   docker run -d --name dd-agent \
#     -e DD_API_KEY=sua_chave_aqui \
#     -e DD_APM_ENABLED=true \
#     -e DD_APM_NON_LOCAL_TRAFFIC=true \
#     -e DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true \
#     -p 8126:8126 \
#     -p 8125:8125/udp \
#     gcr.io/datadoghq/agent:7
#
# Sem o agente rodando em localhost:8126 (APM) e localhost:8125 (DogStatsD),
# os dados são descartados silenciosamente — sem erro, sem aviso.
#
# Para rodar SEM Datadog (modo padrão local):
#   DD_TRACE_ENABLED=false
#   DD_LOGS_INJECTION=false
#
# Para rodar COM Datadog (requer agente acima):
#   DD_TRACE_ENABLED=true
#   DD_LOGS_INJECTION=true  ← ATENÇÃO: desativa pino-pretty, logs saem em JSON
# ---------------------------------------------------------------------------
DD_TRACE_ENABLED=false
DD_SERVICE=payments-api
DD_ENV=local
DD_VERSION=0.0.1
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125
DD_RUNTIME_METRICS_ENABLED=false
DD_LOGS_INJECTION=false
# DD_SITE: target Datadog intake. Default is datadoghq.com (US1).
# EU accounts: datadoghq.eu | US3: us3.datadoghq.com | US5: us5.datadoghq.com
DD_SITE=datadoghq.com

# DD_API_KEY: obrigatória para o DD Agent exportar dados.
# Em AWS, injete essa chave durante o deploy; nao use Secrets Manager neste template.
# DD_API_KEY=
