# Payments API — Local Development Configuration
# Copy this file to .env and fill in your values.
# .env is ignored by git — never commit secrets.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PORT=3011
NODE_ENV=development
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# API Token Authentication
#
# API_TOKEN_LOCAL: token pré-cadastrado para desenvolvimento local.
#   - Habilitado automaticamente em qualquer NODE_ENV.
#   - Associado ao tenant "local" e tokenId "local-dev".
#   - Use este valor no header X-Api-Token ao testar localmente.
#   - Não use este valor em ambientes de staging ou produção.
# ---------------------------------------------------------------------------
API_TOKEN_LOCAL=local-dev-token-insecure-do-not-use-in-prod

# ---------------------------------------------------------------------------
# Payment providers
# ---------------------------------------------------------------------------
ENABLED_PAYMENT_PROVIDERS=ASAAS
DEFAULT_PAYMENT_PROVIDER=ASAAS

# ---------------------------------------------------------------------------
# Asaas provider
# ---------------------------------------------------------------------------
ASAAS_MOCK=true
ASAAS_TOKEN=your_asaas_sandbox_token_here
ASAAS_URL=https://api-sandbox.asaas.com
ASAAS_WEBHOOK_TOKEN=
# Local NestJS default is sync. SAM/LocalStack deploy overrides this to async.
WEBHOOK_PROCESSING_MODE=sync
WEBHOOK_QUEUE_URL=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DYNAMODB_ENDPOINT=http://localhost.localstack.cloud:4566
AWS_SQS_ENDPOINT=http://localhost.localstack.cloud:4566

# ---------------------------------------------------------------------------
# Staging
#
# Essas variáveis são geradas automaticamente por scripts/sync-staging-env.sh
# e usadas por scripts/test-invoice.sh para testar contra o ambiente staging.
#
# STAGING_ADMIN_SECRET: secret para autenticar em POST /admin/tokens no staging.
# ---------------------------------------------------------------------------
STAGING_API_URL=
STAGING_API_TOKEN=
STAGING_WEBHOOK_QUEUE_URL=
STAGING_WEBHOOK_DLQ_URL=
STAGING_ADMIN_SECRET=

# ---------------------------------------------------------------------------
# Experiment Sandbox
#
# Usadas por scripts/setup-experiment-sandbox.sh para criar o GitHub Environment
# 'experiment' e o IAM role payments-api-github-experiment.
# Executar apenas uma vez (ou ao rotacionar segredos):
#
#   export EXPERIMENT_ASAAS_TOKEN="..."
#   export EXPERIMENT_ASAAS_WEBHOOK_TOKEN="..."
#   export EXPERIMENT_ADMIN_SECRET="..."
#   ./scripts/setup-experiment-sandbox.sh <org>/<repo>
#
# Ou com sourcing automático: adicione os valores abaixo e rode o script
# diretamente — ele carrega api/.env automaticamente.
#
# Nota: o ambiente experiment usa a mesma conta Asaas sandbox que o staging,
# mas dados ficam isolados pelo prefixo experiment-* nas tabelas DynamoDB.
# ---------------------------------------------------------------------------
EXPERIMENT_ASAAS_TOKEN=
EXPERIMENT_ASAAS_WEBHOOK_TOKEN=
EXPERIMENT_ADMIN_SECRET=

# ---------------------------------------------------------------------------
# Experiment Sandbox — conexão AWS
#
# Gerado automaticamente por scripts/sync-experiment-env.sh após o deploy
# do sandbox de experimento. Regenere com:
#
#   ./scripts/sync-experiment-env.sh
#
# Apagado/invalidado automaticamente ao executar teardown do stack.
# ---------------------------------------------------------------------------
EXPERIMENT_API_URL=
EXPERIMENT_API_TOKEN=
EXPERIMENT_WEBHOOK_QUEUE_URL=
EXPERIMENT_WEBHOOK_DLQ_URL=

# ---------------------------------------------------------------------------
# Datadog
#
# PRÉ-REQUISITO LOCAL: um DD Agent deve estar rodando para que traces e métricas
# cheguem ao Datadog. Suba o agente com Docker antes de ligar o tracing:
#
#   docker run -d --name dd-agent \
#     -e DD_API_KEY=sua_chave_aqui \
#     -e DD_APM_ENABLED=true \
#     -e DD_APM_NON_LOCAL_TRAFFIC=true \
#     -e DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true \
#     -p 8126:8126 \
#     -p 8125:8125/udp \
#     gcr.io/datadoghq/agent:7
#
# Sem o agente rodando em localhost:8126 (APM) e localhost:8125 (DogStatsD),
# os dados são descartados silenciosamente — sem erro, sem aviso.
#
# Para rodar SEM Datadog (modo padrão local):
#   DD_TRACE_ENABLED=false
#   DD_LOGS_INJECTION=false
#
# Para rodar COM Datadog (requer agente acima):
#   DD_TRACE_ENABLED=true
#   DD_LOGS_INJECTION=true  ← ATENÇÃO: desativa pino-pretty, logs saem em JSON
# ---------------------------------------------------------------------------
DD_TRACE_ENABLED=false
DD_SERVICE=payments-api
DD_ENV=local
DD_VERSION=0.0.1
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125
DD_RUNTIME_METRICS_ENABLED=false
DD_LOGS_INJECTION=false
# DD_SITE: target Datadog intake. Default is datadoghq.com (US1).
# EU accounts: datadoghq.eu | US3: us3.datadoghq.com | US5: us5.datadoghq.com
DD_SITE=datadoghq.com

# DD_API_KEY: obrigatória para o DD Agent exportar dados.
# Em AWS, injete essa chave durante o deploy; nao use Secrets Manager neste template.
# DD_API_KEY=
